# =====================================================
# URLEncurta.com.br - Variáveis de Ambiente
# =====================================================
# Nunca commite valores reais. Use .env.local localmente e Environment Variables no Vercel.

# App
NEXT_PUBLIC_APP_URL=https://urlencurta.com.br
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# AuthJS / NextAuth
# Gere com: openssl rand -base64 32
AUTH_SECRET=change-me-with-a-strong-secret
NEXTAUTH_SECRET=change-me-with-a-strong-secret
NEXTAUTH_URL=https://urlencurta.com.br

# Banco de dados PostgreSQL
# Use a connection string com SSL. Em produção, configure no Vercel.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Opcionais para desenvolvimento/teste
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
