# =====================================================
# URLEncurta.com.br - Variáveis de Ambiente
# =====================================================

# Banco de dados Neon (PostgreSQL)
# Obtenha em: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# URL base do aplicativo
NEXT_PUBLIC_APP_URL=https://urlencurta.com.br

# =====================================================
# Stripe - Pagamentos (https://stripe.com)
# =====================================================
# Chaves de teste (obtenha em: https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ID do preço do produto Premium (crie em: https://dashboard.stripe.com/test/products)
# O price ID tem o formato: price_XXXXXXXXXXXXX
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly

# =====================================================
# Configurações Opcionais
# =====================================================
# NEXTAUTH_SECRET=your_secret_here (se usar autenticação)
# NEXTAUTH_URL=https://urlencurta.com.br (se usar autenticação)
